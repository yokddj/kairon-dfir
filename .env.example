# DFIR APP beta environment template.
# Copy to .env and replace every CHANGE_ME value before use.

POSTGRES_DB=dfir
POSTGRES_USER=dfir
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0

OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=CHANGE_ME_OPENSEARCH_PASSWORD
OPENSEARCH_INITIAL_ADMIN_PASSWORD=CHANGE_ME_STRONG_INITIAL_ADMIN_PASSWORD
OPENSEARCH_SSL=false
OPENSEARCH_VERIFY_CERTS=false
OPENSEARCH_INDEX_PREFIX=dfir-events
OPENSEARCH_JAVA_HEAP=2g

OPENSEARCH_DASHBOARDS_ENABLED=true
OPENSEARCH_DASHBOARDS_INTERNAL_URL=http://opensearch-dashboards:5601
OPENSEARCH_DASHBOARDS_PUBLIC_URL=http://localhost:5601
OPENSEARCH_DASHBOARDS_INDEX_PATTERN=dfir-events-*
OPENSEARCH_DASHBOARDS_TIME_FIELD=@timestamp

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:5173
BACKEND_MAX_UPLOAD_SIZE=2147483648
BACKEND_DATA_DIR=/app/data
BACKEND_TEMP_DIR=/app/data/tmp
BACKEND_LOG_LEVEL=INFO
BACKEND_UVICORN_WORKERS=1

# Server-side evidence path import is disabled by default.
DFIR_ALLOW_HOST_PATH_IMPORT=false
DFIR_ALLOWED_EVIDENCE_ROOTS=/mnt/evidence,/data/evidence,/cases

# Beta defaults: clean investigation mode. Enable only for demo/training/QA.
DFIR_ENABLE_DEMO_CASES=false
DFIR_ENABLE_VALIDATION_FEATURES=false
DFIR_DEFAULT_CASE_MODE=investigation

# Extraction and ingest guardrails.
BACKEND_MAX_EXTRACTED_FILES=20000
BACKEND_MAX_EXTRACTED_BYTES=2147483648
INGEST_BATCH_SIZE=1000
OPENSEARCH_BULK_DOCS=1000
OPENSEARCH_BULK_BYTES=10485760
MAX_PARALLEL_ARTIFACTS=1
MAX_PARALLEL_RULE_RUNS=1
SEARCH_DEFAULT_PAGE_SIZE=50
SEARCH_MAX_PAGE_SIZE=1000

# Rules are run manually after indexing. Keep broad scans bounded.
AUTO_CREATE_HEURISTIC_DETECTIONS=true
YARA_SCAN_RAW_EVIDENCE=true
YARA_SCAN_PARSED_OUTPUTS=false
YARA_SCAN_ARCHIVES=false
YARA_SCAN_TEXT_OUTPUTS=false
YARA_MAX_FILE_SIZE_MB=100

# Memory Analysis isolated foundation. External tools are optional and not bundled.
MEMORY_ANALYSIS_ENABLED=false
MEMORY_ALLOW_EXTERNAL_TOOL_EXECUTION=false
VOLATILITY3_COMMAND=vol
MEMPROCFS_COMMAND=memprocfs
MEMORY_BACKEND_CHECK_TIMEOUT_SECONDS=10
MEMORY_BACKEND_STATUS_CACHE_SECONDS=60
MEMORY_PREFERRED_BACKEND=volatility3
MEMORY_UPLOAD_ENABLED=false
MEMORY_UPLOAD_MAX_BYTES=34359738368
MEMORY_UPLOAD_DIRECT_THRESHOLD_BYTES=1073741824
MEMORY_UPLOAD_CHUNK_SIZE_BYTES=67108864
MEMORY_UPLOAD_DEFAULT_CONCURRENCY=2
MEMORY_UPLOAD_MAX_CONCURRENCY=4
MEMORY_UPLOAD_SESSION_TTL_HOURS=24
MEMORY_UPLOAD_STAGING_ROOT=
MEMORY_UPLOAD_CLEANUP_AGE_SECONDS=86400
MEMORY_UPLOAD_REQUEST_TIMEOUT_SECONDS=0
MEMORY_UPLOAD_VERIFICATION_TIMEOUT_SECONDS=300
MEMORY_UPLOAD_FINALIZATION_TIMEOUT_SECONDS=120
MEMORY_UPLOAD_STALE_TIMEOUT_SECONDS=900
MEMORY_UPLOAD_ALLOWED_EXTENSIONS=.raw,.mem,.vmem,.dmp,.lime
MEMORY_JOB_TIMEOUT_SECONDS=900
MEMORY_PLUGIN_TIMEOUT_SECONDS=600
MEMORY_PLUGIN_OUTPUT_MAX_BYTES=10485760
MEMORY_OUTPUT_DIR=
MEMORY_WORKER_MODE=external_command
MEMORY_TASK_QUEUE=memory
MEMORY_REQUIRE_DEDICATED_WORKER=true
MEMORY_WORKER_CONCURRENCY=1
MEMORY_ALLOWED_PLUGINS=windows.info,windows.pslist,windows.pstree,windows.psscan,windows.cmdline
MEMORY_ALLOWED_PROFILES=metadata_only,processes_basic,processes_extended
MEMORY_DEFAULT_PROFILE=metadata_only
MEMORY_PROCESS_PROFILE_ENABLED=false
MEMORY_MAX_PROCESS_ROWS=100000
MEMORY_MAX_COMMAND_LINE_LENGTH=16384
MEMORY_MAX_RAW_FIELD_LENGTH=65536
MEMORY_RAW_OUTPUT_RETENTION_ENABLED=true
MEMORY_SYMBOL_NETWORK_ACCESS_ENABLED=false
MEMORY_SYMBOL_MODE=offline_only
MEMORY_SYMBOL_MANAGED_DOWNLOAD_ENABLED=false
MEMORY_SYMBOL_ALLOWED_HOSTS=
MEMORY_SYMBOL_DOWNLOAD_TIMEOUT_SECONDS=180
MEMORY_SYMBOL_CONNECT_TIMEOUT_SECONDS=15
MEMORY_SYMBOL_MAX_REDIRECTS=5
MEMORY_SYMBOL_DOWNLOAD_MAX_BYTES=1073741824
MEMORY_SYMBOL_ISF_MAX_BYTES=268435456
MEMORY_SYMBOL_CACHE_MAX_BYTES=5368709120
MEMORY_SYMBOL_CACHE_ROOT=/volatility-cache
MEMORY_SYMBOL_DOWNLOAD_CONCURRENCY=1
MEMORY_SYMBOL_TASK_QUEUE=memory-symbols
MEMORY_SYMBOL_PARTIAL_TTL_SECONDS=86400
MEMORY_SYMBOL_REQUEST_STALE_SECONDS=900
MEMORY_SYMBOL_INITIAL_HOST=msdl.microsoft.com
MEMORY_SYMBOL_REDIRECT_SUFFIXES=.blob.core.windows.net
MEMORY_SYMBOL_NETWORK_ISOLATION_READY=false
MEMORY_SYMBOL_ADMIN_AUTHORIZATION_ENFORCED=false
MEMORY_SYMBOL_ADMIN_AUTHORIZATION_REQUIRED=true

# Egress gateway: the symbol-fetcher talks to this service over the
# symbol-internal Docker network.  The fetcher has no direct Internet
# route.  The gateway secret MUST be set (server-generated, never
# committed, rotatable) before the symbol-egress-gateway container is
# brought up.  See docs/symbol_egress_gateway.md.
MEMORY_SYMBOL_EGRESS_GATEWAY_URL=http://symbol-egress-gateway:8443
MEMORY_SYMBOL_EGRESS_GATEWAY_SECRET=
MEMORY_SYMBOL_EGRESS_GATEWAY_PORT=8443
MEMORY_SYMBOL_EGRESS_REPLAY_WINDOW_SECONDS=60
MEMORY_SYMBOL_EGRESS_MAX_RESPONSE_BYTES=1073741824

# Local-operator approval for managed symbol acquisition.  The flag MUST
# default to false.  When true, an operator can approve a pending request
# via the CLI documented in docs/memory_symbol_operator_approval.md.
MEMORY_SYMBOL_LOCAL_APPROVAL_ENABLED=false
MEMORY_SYMBOL_APPROVAL_TTL_SECONDS=600
MEMORY_SYMBOL_APPROVAL_SINGLE_USE=true

# Optional memory-worker image build metadata. The memory profile is not built or
# started unless an operator explicitly runs docker compose --profile memory ...
VOLATILITY3_VERSION=2.28.0
KAIRON_COMMIT=unknown
BUILD_DATE=unknown

# Frontend build/runtime API target.
FRONTEND_API_BASE_URL=http://localhost:8000/api

# Optional helper scripts.
DFIR_BACKEND_URL=http://127.0.0.1:8000
DFIR_FRONTEND_URL=http://127.0.0.1:5173
DFIR_BACKUP_ROOT=./backups
